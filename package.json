{
  "name": "agentpwd",
  "version": "0.0.1",
  "description": "Credential management for AI agents — agents fill the form, never see the password.",
  "type": "module",
  "bin": {
    "ap": "./dist/cli/index.js",
    "ap-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && chmod +x dist/cli/index.js dist/mcp/server.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uvollmer/agentpwd"
  },
  "author": "uvollmer",
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^22.13.9",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ciphers": "^1.3.0",
    "@noble/hashes": "^1.8.0",
    "better-sqlite3": "^11.10.0",
    "chrome-remote-interface": "^0.34.0",
    "commander": "^13.1.0",
    "keytar": "^7.9.0",
    "zod": "^4.4.3"
  }
